---
const year = new Date().getFullYear();
---

<footer class="fp-footer">
  <div class="fp-footer-row">
    <div class="fp-footer-mark">
      <span class="fp-mark-dot"></span>
      <span class="fp-mark-name">fujioha</span>
      <span class="fp-etymology" title="etymology of fujioha">
        <span class="fp-mono fp-faint fp-etymology-mark">= ?</span>
        <span class="fp-mono fp-etymology-full"
          >= 十八番 (signature) + おはよう (good morning)</span
        >
      </span>
    </div>
    <div class="fp-footer-meta fp-mono fp-faint" data-footer-year>
      © 2024–{year} · by @nickname
    </div>
  </div>
</footer>
