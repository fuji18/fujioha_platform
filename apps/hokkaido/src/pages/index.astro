---
import BaseLayout from '../layouts/BaseLayout.astro';
import PortalTop from '@fujioha/ui/components/PortalTop.astro';
import PortalFooter from '@fujioha/ui/components/PortalFooter.astro';
import Hero from '../components/Hero.astro';
import ComingSoon from '../components/ComingSoon.astro';
import Companions from '../components/Companions.astro';
// 現在このサイトは準備中。記事が整うまで、各セクション（Featured/Cities/
// Themes/Recent/Local）は表に出さず、ComingSoon の案内のみを表示する。
---

<BaseLayout>
  <div class="hk">
    <PortalTop sub="hokkaido" subJp="北海道の歩き方" />
    <Hero />
    <ComingSoon />
    <Companions />
    <PortalFooter
      sub="hokkaido"
      siblingSub="game"
      siblingJp="思いつきの Web ゲーム"
      siblingEn="Small web games, made by hand"
      siblingHref="https://game.fujioha.com/"
    />
  </div>
</BaseLayout>
