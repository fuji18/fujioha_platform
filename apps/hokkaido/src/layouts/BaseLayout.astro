---
import '@fujioha/ui/styles/tokens.css';
import '@fujioha/ui/styles/chrome.css';
import '../styles/global.css';
import SeoHead from '@fujioha/ui/components/SeoHead.astro';
import { buildWebSiteSchema } from '@fujioha/ui/structured-data';

interface Props {
  title?: string;
  description?: string;
  /** ページ固有の構造化データ。WebSite と統合して出力する（公開後に利用）。 */
  structuredData?: Record<string, unknown> | Record<string, unknown>[];
}

const {
  title = '北海道の歩き方 — hokkaido.fujioha.com',
  description = '地元の人が解説する、観光ガイドにない北海道。',
  structuredData,
} = Astro.props;

// 現在は noindex のため SeoHead 側で JSON-LD は出力されないが、公開（noindex 解除）
// 時に自動で構造化データが付くよう配線しておく。
const websiteSchema = buildWebSiteSchema({
  name: 'ふじおは — 北海道の歩き方',
  url: Astro.site?.href ?? 'https://hokkaido.fujioha.com',
  description,
});

const extraSchemas = Array.isArray(structuredData)
  ? structuredData
  : structuredData
    ? [structuredData]
    : [];
const allSchemas = [websiteSchema, ...extraSchemas];
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    {/* 旧デプロイ(PWA)が残した Service Worker を掃除するセーフティネット。
        登録パスに依らず全 SW を unregister し、Cache Storage を全削除する。
        第1段の駆除は public/sw.js を参照。 */}
    <script is:inline>
      if ('serviceWorker' in navigator) {
        navigator.serviceWorker
          .getRegistrations()
          .then(function (registrations) {
            registrations.forEach(function (registration) {
              registration.unregister();
            });
          })
          .catch(function () {});
        if (window.caches && caches.keys) {
          caches
            .keys()
            .then(function (keys) {
              keys.forEach(function (key) {
                caches.delete(key);
              });
            })
            .catch(function () {});
        }
      }
    </script>
    <title>{title}</title>
    {/* サイトは準備中のため検索インデックスさせない */}
    <SeoHead
      title={title}
      description={description}
      image="/og.png"
      noindex
      structuredData={allSchemas}
    />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link
      rel="alternate"
      type="application/rss+xml"
      title="hokkaido.fujioha.com — 更新"
      href="/rss.xml"
    />
    <link
      rel="alternate"
      type="application/atom+xml"
      title="hokkaido.fujioha.com — 更新"
      href="/atom.xml"
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Shippori+Mincho+B1:wght@400;500;600;700&family=Zen+Kaku+Gothic+New:wght@400;500;700&family=Newsreader:ital,opsz,wght@0,6..72,400;0,6..72,500;0,6..72,600;1,6..72,400&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <slot />
  </body>
</html>
